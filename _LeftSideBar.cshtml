    <script>

        function databindkeywords(searchText = '') {
            $.ajax({
                url: '/Home/GetSuggestions',
                type: 'GET',
                success: function (result) {
                    var $ul = $('#suggestions-list');
                    $ul.empty();

                    $.each(result, function (index, item) {
                        var $li = $('<li class="suggestion-item"></li>');

                        var $spanText = $('<span class="text-item"></span>')
                            .text(item.Key_Words)
                            .click(function () {
                                selectSuggestion(item.Path, item.Key_Id);
                            });

                        var $spanStar;
                        if (item.BookMarked) {
                            $spanStar = $('<span class="star-icon" style="color: #4999CC;" title="Edit Bookmark for this Keyword">&#9733;</span>')
                                .click(function () {
                                    toggleBookmark(this, item.Key_Id, item.BookMarked);
                                });
                        } else {
                            $spanStar = $('<span class="star-icon" style="color: gray;" title="BookMark for this Keyword">&#9734;</span>')
                                .click(function () {
                                    toggleBookmark(this, item.Key_Id, item.BookMarked);
                                });
                        }

                        $li.append($spanText).append($spanStar);
                        $ul.append($li);
                    });

                    if (searchText.trim() !== '') {
                        filterSuggestions(searchText);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error loading suggestions:', error);
                }
            });
        }

    </script>


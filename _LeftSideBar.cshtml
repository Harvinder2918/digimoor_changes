                max-width: 100%;
                height: auto;
            }

        /* Ensure navbar shows the logo */
        .navbar-static-top .logo-here {
            display: inline-block !important;
         
            margin-right: 15px;
        }


        aside.main-sidebar {
            position: fixed;
            top: 0px;
        }

        .dropdown-menu > .active > a,
        .dropdown-menu > .active > a:focus,
        .dropdown-menu > .active > a:hover {
            background-color: #eaeef3 !important; /* your custom color */
            color: #262626 !important;
        }

        #txtchatbot {
            height: auto;
        }



        .find-button {
            display: flex;
            align-items: center;
            background-color: #1e3352;
            color: white;
            padding: 8px 25px 10px 1px;
            border-radius: 40px;
            cursor: pointer;
            transition: transform 0.2s;
            position: relative;
            width: 235px;
            height: 68px;
            box-shadow: 5px 1px 17.9px 1.5px rgba(0, 160, 228, 0.8);
            animation: glowing-button 4s ease-in-out infinite alternate;
        }



        .plus-container {
            width: 90px;
            height: 90px;
            background: #213556;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            position: absolute;
            left: -46px;
            top: -11px;
            z-index: 2;
            border: 3px solid #00A0E4;
            box-shadow: 5px 1px 17.9px 1.5px rgba(0,160,228,0.8);
            animation: glowing-plus 2s ease-in-out infinite alternate;
        }

        /* The plus shape */
        .plus-icon {
            width: 48px; /* overall size of the plus */
            height: 48px;
            position: relative;
            display: block;
        }

            .plus-icon::before,
            .plus-icon::after {
                content: "";
                position: absolute;
                left: 50%;
                top: 50%;
                background: #fff;
                border-radius: 3px;
                transform: translate(-50%, -50%);
            }

            /* horizontal bar */
            .plus-icon::before {
                width: 60%;
                height: 6px; /* thickness */
            }

            /* vertical bar */
            .plus-icon::after {
                width: 6px;
                height: 60%;
            }



        .button-text {
            font-size: 18px;
            font-weight: 500;
            letter-spacing: 0.5px;
            white-space: nowrap;
            padding-left: 54px;
            animation: glowing-text 3s ease-in-out infinite alternate;
        }



        /* Subtle glow for entire button */

        /* Subtle glow for entire button */

        @@keyframes glowing-button {

            0% {
                box-shadow: 5px 1px 18px 1.5px rgba(0, 160, 228, 0.6);
            }

            50% {
                box-shadow: 5px 1px 24px 3px rgba(0, 160, 228, 0.85);
            }

            100% {
                box-shadow: 5px 1px 18px 1.5px rgba(0, 160, 228, 0.6);
            }
        }







        /* Strong glow animation for plus-container */

        @@keyframes glowing-plus {

            0% {
                box-shadow: 0 0 10px rgba(0, 160, 228, 0.6), 0 0 20px rgba(0, 160, 228, 0.4), 0 0 5px #00A0E4;
            }

            50% {
                box-shadow: 0 0 25px rgba(0, 160, 228, 1), 0 0 50px rgba(0, 160, 228, 0.8), 0 0 12px #00A0E4;
            }

            100% {
                box-shadow: 0 0 10px rgba(0, 160, 228, 0.6), 0 0 20px rgba(0, 160, 228, 0.4), 0 0 5px #00A0E4;
            }
        }





        /* Light glow animation for text */

        @@keyframes glowing-text {

            0% {
                text-shadow: 0 0 4px rgba(0, 160, 228, 0.4), 0 0 8px rgba(0, 160, 228, 0.2);
            }

            50% {
                text-shadow: 0 0 6px rgba(0, 160, 228, 0.6), 0 0 12px rgba(0, 160, 228, 0.4);
            }

            100% {
                text-shadow: 0 0 4px rgba(0, 160, 228, 0.4), 0 0 8px rgba(0, 160, 228, 0.2);
            }
        }







        .search-bar {
            width: 100%;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            min-height: 66px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.2);
            margin-top: 30px;
        }

        .visited-pages.mt-4 h3 {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        button#show-all-visited {
            background: transparent;
            font-size: 16px;
            color: #4999CC;
            font-weight: 700;
        }

        ul#bookmarked-pages li {
            margin-bottom: 0px !important;
        }

        .modal-content {
            width: 900px;
            margin: 0 auto;
            margin-top: 2%;
        }

        #ui-datepicker-div {
            z-index: 1111 !IMPORTANT;
        }
        /* ---------- external tiny controls ---------- */
        .chat-external-controls {
            position: absolute;
            top: -14px; /* lifts the controls above the pot */
            right: 6px; /* align visually over your circle */
            display: flex;
            gap: 6px;
            z-index: 5;
            pointer-events: auto;
        }

        .external-btn {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid #00A0E4;
            background: #1e3352;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 14px rgba(0,160,228,0.45);
            cursor: pointer;
            padding: 0;
            line-height: 0;
            outline: none;
        }

            .external-btn i {
                font-size: 14px;
            }

            .external-btn:hover {
                transform: translateY(-1px);
                transition: transform .12s ease;
            }

        /* keep your existing plus-container & plus icon look */
        .plus-container {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .plus-icon {
            width: 48px;
            height: 48px;
            position: relative;
            display: block;
        }

            .plus-icon::before,
            .plus-icon::after {
                content: "";
                position: absolute;
                left: 50%;
                top: 50%;
                background: #fff;
                border-radius: 3px;
                transform: translate(-50%,-50%);
            }

            .plus-icon::before {
                width: 60%;
                height: 6px;
            }
            /* horizontal */
            .plus-icon::after {
                width: 6px;
                height: 60%;
            }
        /* vertical */

        /* ---------- two visual states ---------- */
        /* default: EXPANDED state (big pill visible, external minus shown) */
        #chatbot {
            width: auto;
            height: auto;
        }

            #chatbot.expanded .find-button {
                display: flex;
                width: 235px;
                height: 68px;
                align-items: center;
            }

            #chatbot.expanded .chat-external-controls .min-btn {
                display: inline-flex;
            }

            #chatbot.expanded .chat-external-controls .max-btn {
                display: none;
            }

            /* COLLAPSED state: hide the main button completely, only show plus-container */
            #chatbot.collapsed .find-button {
                display: none !important;
            }

            /* Show collapsed circle button only when collapsed */
            #chatbot.collapsed .collapsed-circle-btn {
                display: flex !important;
                width: 52px;
                height: 52px;
                border-radius: 50%;
                background: #213556;
                border: 3px solid #00A0E4;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                position: fixed;
                bottom: 30px;
                right: 30px;
                z-index: 1112 !important; /* Higher than main-header (1111) to appear above menu */
                overflow: visible !important;
                clip: auto !important;
                clip-path: none !important;
            }

                #chatbot.collapsed .collapsed-circle-btn .plus-container {
                    width: 48px;
                    height: 48px;
                    position: static;
                    background: transparent;
                    border: none;
                    box-shadow: none;
                    animation: none;
                }

            #chatbot.expanded .collapsed-circle-btn {
                display: none !important;
            }

            #chatbot.collapsed .chat-external-controls .min-btn {
                display: none;
            }
            /* hide minus when compact */
            #chatbot.collapsed .chat-external-controls .max-btn {
                display: inline-flex;
            }
        /* show external plus when compact */

        /* small transitions for smoothness */
        .find-button, .plus-container {
            transition: all .18s ease;
        }

        /* mobile tweak */
        @@media (max-width:460px) {
            .chat-external-controls {
                right: 2px;
                top: -12px;
            }

            .external-btn {
                width: 26px;
                height: 26px;
            }

            #chatbot.collapsed .find-button .plus-container {
                width: 66px;
                height: 66px;
            }
        }


        /* Make sure the collapsed state uses the transparent background you want */
        #chatbot.collapsed .find-button {
            background: transparent !important;
        }

        /* Keep the inner plus white and visible (adjust if you want different look) */
        #chatbot.collapsed .plus-icon::before,
        #chatbot.collapsed .plus-icon::after {
            background: #fff !important;
        }

        #chatbot {
            position: fixed !important;
            bottom: 30px;
            right: 30px;
            overflow: visible !important;
            z-index: 1112 !important; /* Higher than main-header (1111) to appear above menu */
        }

            /* Keep size same so no slide/movement happens */
            #chatbot.collapsed {
                width: auto !important;
                height: auto !important;
                overflow: visible !important;
            }

            /* Dragging state - prevent text selection during drag */
            #chatbot.dragging {
                user-select: none;
                -webkit-user-select: none;
                -moz-user-select: none;
                -ms-user-select: none;
                cursor: move !important;
            }

                /* Hide tooltip text during drag */
                #chatbot.dragging .button-text1 {
                    display: none !important;
                    opacity: 0 !important;
                }

            /* Prevent native tooltips on collapsed button during interaction */
            #chatbot.collapsed .collapsed-circle-btn[title],
            #chatbot.collapsed .collapsed-circle-btn *[title] {
                position: relative;
            }

        /* Cursor styles - move for draggable areas, pointer for interactive elements */
        #chatbot {
            cursor: move;
        }

            /* Reset cursor for interactive elements inside chatbot */
            #chatbot .external-btn,
            #chatbot .button-text,
            #chatbot .button-text1,
            #chatbot span:not(.collapsed-circle-btn span),
            #chatbot i {
                cursor: pointer;
            }

            /* Collapsed circle button should be draggable */
            #chatbot.collapsed .collapsed-circle-btn {
                cursor: move !important;
            }

                /* Plus icon inside collapsed button should also be move cursor - override any span rules */
                #chatbot.collapsed .collapsed-circle-btn .plus-container,
                #chatbot.collapsed .collapsed-circle-btn .plus-icon,
                #chatbot.collapsed .collapsed-circle-btn span {
                    cursor: move !important;
                }

        /* Tooltip for plus-icon - modern, polished design */
        .collapsed-circle-btn .plus-icon-tooltip {
            display: none;
            position: fixed !important;
            background: linear-gradient(135deg, #213556 0%, #1a2a42 100%);
            color: #ffffff;
            padding: 10px 16px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.4;
            text-align: left;
            white-space: nowrap !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), 0 2px 8px rgba(0, 160, 228, 0.2);
            z-index: 99999999 !important;
            pointer-events: none;
            opacity: 0;
            transform: translateY(5px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            width: max-content !important;
            min-width: 240px !important;
            max-width: 350px !important;
            overflow: visible !important;
            word-wrap: normal !important;
            text-overflow: clip !important;
            box-sizing: border-box;
            clip: auto !important;
            clip-path: none !important;
            border: 1px solid rgba(0, 160, 228, 0.3);
            /* Position will be calculated by JavaScript */
        }

        /* Show tooltip with smooth animation */
        .collapsed-circle-btn:hover .plus-icon-tooltip,
        .collapsed-circle-btn .plus-icon:hover ~ .plus-icon-tooltip {
            opacity: 1;
            transform: translateY(0);
        }

        /* Arrow pointing down to the icon - positioned at bottom center, pointing to button */
        .collapsed-circle-btn .plus-icon-tooltip::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: var(--arrow-left, 50%);
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-top: 8px solid #213556;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
            transition: left 0.2s ease;
        }

        /* Arrow border for depth */
        .collapsed-circle-btn .plus-icon-tooltip::before {
            content: '';
            position: absolute;
            bottom: -9px;
            left: var(--arrow-left, 50%);
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 9px solid transparent;
            border-right: 9px solid transparent;
            border-top: 9px solid rgba(0, 160, 228, 0.3);
            z-index: -1;
            transition: left 0.2s ease;
        }

        /* When tooltip is below the button, arrow points up */
        .collapsed-circle-btn .plus-icon-tooltip.tooltip-below::after {
            bottom: auto;
            top: -8px;
            left: var(--arrow-left, 50%);
            transform: translateX(-50%);
            border-top: none;
            border-bottom: 8px solid #213556;
        }

        .collapsed-circle-btn .plus-icon-tooltip.tooltip-below::before {
            bottom: auto;
            top: -9px;
            left: var(--arrow-left, 50%);
            transform: translateX(-50%);
            border-top: none;
            border-bottom: 9px solid rgba(0, 160, 228, 0.3);
        }

        /* Show tooltip ONLY when hovering over the plus-icon or plus-container */
        .collapsed-circle-btn .plus-icon:hover ~ .plus-icon-tooltip,
        .collapsed-circle-btn:hover .plus-icon-tooltip,
        .collapsed-circle-btn:has(.plus-icon:hover) .plus-icon-tooltip,
        .collapsed-circle-btn:has(.plus-container:hover) .plus-icon-tooltip {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        /* Hide tooltip during drag */
        #chatbot.dragging .plus-icon-tooltip {
            display: none !important;
            opacity: 0 !important;
        }

        /* Ensure parent containers don't clip the tooltip
        body, html, .wrapper, .content-wrapper, #chatbot, #chatbot.collapsed {
            overflow-x: visible !important;
        }*/

        /* Override any table or container overflow that might clip tooltip */
        table, .table, .container, .row, .col-md-*, [class*="container"] {
            position: relative;
        }

        /* Ensure tooltip can escape any overflow hidden containers */
        .plus-icon-tooltip {
            position: fixed !important;
            transform: none !important;
        }

        /* Make the plus-container and main chatbot area draggable */
        #chatbot .plus-container,
        #chatbot .find-button:not(:hover) {
            cursor: move;
        }

        #chatbot .chat-external-controls .button-text1 {
            display: none;
            position: absolute;
            right: 6px; /* aligns with external controls */
            top: -29px; /* above the pot; adjust as needed */
            background: #213556;
            color: #fff;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 14px;
            line-height: 1.2;
            text-align: center;
            white-space: nowrap;
            box-shadow: 0 6px 18px rgba(0,160,228,0.22);
            z-index: 9999;
            transform-origin: 50% 100%;
            opacity: 0;
            transition: opacity .18s ease, transform .18s ease;
            pointer-events: none; /* tooltip doesn't capture pointer (so clicks go to buttons) */
        }



        /* Hide tooltip completely - both collapsed and expanded states */
        #chatbot.collapsed .chat-external-controls .button-text1,
        #chatbot.expanded .chat-external-controls .button-text1 {
            display: none !important;
            opacity: 0 !important;
        }

        /* Prevent tooltip from showing on hover in any state */
        #chatbot:hover .chat-external-controls .button-text1,
        #chatbot .find-button:hover ~ .chat-external-controls .button-text1 {
            display: none !important;
            opacity: 0 !important;
        }


        /* small responsiveness tweaks */
        @@media (max-width:460px) {
            #chatbot .chat-external-controls .button-text1 {
                top: -48px;
                font-size: 13px;
                right: 4px;
            }
        }

        .chatbot-open {
            min-height: 797px;
            display: block !important;
        }
    </style>




    <script>
        $(document).ready(function () {

            var url = window.location;
            var element = $('.main-nav li a').filter(function () {
                return this.href == url || url.href.indexOf(this.href) == 0;
            });
            $(element).parentsUntil('.main-nav', 'li').addClass('active').find(".dropdown_menu").slideDown().next(".sub-indicator").addClass("sub-arrow-open");

            var currentPath = window.location.pathname.toLowerCase();

            // Remove all active classes first
            $('.sidebar-menu li').removeClass('active');

            // Loop through each link and match with current URL
            $('.sidebar-menu li a').each(function () {
                var href = $(this).attr('href');
                if (!href) return;

                var linkPath = href.toLowerCase();

                if (currentPath === linkPath || currentPath.startsWith(linkPath)) {
                    $(this).closest('li').addClass('active');

                    // Expand parent dropdown
                    $(this).closest('ul.dropdown-menu').css('display', 'block');
                    $(this).parents('li.dropdown').addClass('active');
                }
            });

            // Improve dropdown hover behavior to prevent wrong menu open
            if ($(window).width() > 769) {
                $('.wrapper .dropdown').hover(function () {
                    // Close all dropdowns
                    $('.wrapper .dropdown-menu').slideUp();
                    $('.wrapper .dropdown').removeClass('open');

                    // Open current one
                    $(this).find('.dropdown-menu').first().stop(true, true).delay(10).slideDown();
                    $(this).addClass('open');
                }, function () {
                    $(this).find('.dropdown-menu').first().stop(true, true).delay(10).slideUp();
                    $(this).removeClass('open');
                });

                // Clicking a dropdown parent link navigates
                $('.wrapper .dropdown > a').click(function () {
                    location.href = this.href;
                });
            }

        });
    </script>


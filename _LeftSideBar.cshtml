<script>
    $(function () {
        // Start state: expanded (as you requested in earlier messages)
        $('#chatbot').removeClass('collapsed').addClass('expanded');

        // Click ONLY on external minus => collapse visuals to compact FAB (no panel operations)
        $('#chatbot').off('click', '.min-btn').on('click', '.min-btn', function (e) {
            e.stopPropagation();
            $('#chatbot').removeClass('expanded').addClass('collapsed');
            // Reset chatbot position to default
            $("#chatbot").css({
                'left': 'auto',
                'top': 'auto',
                'right': '30px',
                'bottom': '30px'
            }).show();
            // Also reset collapsed-circle-btn position to default (it has position: fixed)
            $(".collapsed-circle-btn").css({
                'left': 'auto',
                'top': 'auto',
                'right': '30px',
                'bottom': '30px'
            });
        });

        // Click ONLY on external plus (visible when collapsed) => expand visuals to pill (no panel ops)
        $('#chatbot').off('click', '.max-btn').on('click', '.max-btn', function (e) {
            e.stopPropagation();
            $('#chatbot').removeClass('collapsed').addClass('expanded');
        });

        // Click on the collapsed-circle-btn to expand
        $(document).on('click', '#chatbot.collapsed .collapsed-circle-btn', function (e) {
            // Don't expand if we were dragging
            if (window.chatbotWasDragging === true) {
                window.chatbotWasDragging = false;
                return false;
            }
            e.stopPropagation();
            $('#chatbot').removeClass('collapsed').addClass('expanded');
        });

        // ========== DRAG AND DROP FUNCTIONALITY ==========
        // Add drag functionality without affecting existing click handlers
        var isDragging = false;
        var hasMoved = false;
        var startX, startY, initialLeft, initialTop;
        var chatbot = $('#chatbot')[0];
        var dragThreshold = 5; // Minimum pixels to move before considering it a drag
        var dragStartTime = 0;

        // Helper function to check if target is an interactive button
        // Note: collapsed-circle-btn is NOT excluded - it should be draggable
        function isInteractiveButton(target) {
            return $(target).closest('.external-btn').length > 0 ||
                $(target).is('.external-btn');
        }

        // Mouse down event - start drag (on chatbot container)
        $(chatbot).on('mousedown', function (e) {
            // Only exclude actual interactive buttons, not the main button area
            if (isInteractiveButton(e.target)) {
                return; // Let existing click handlers work for buttons
            }

            // If clicking on collapsed-circle-btn or its children, let the specific handler take over
            if ($(e.target).closest('.collapsed-circle-btn').length > 0) {
                return; // Let the collapsed-circle-btn handler handle it
            }

            hasMoved = false;
            isDragging = false;
            dragStartTime = Date.now();

            // Get initial positions
            startX = e.clientX;
            startY = e.clientY;

            var rect = chatbot.getBoundingClientRect();
            initialLeft = rect.left;
            initialTop = rect.top;

            // If collapsed, also get the collapsed-circle-btn position
            if ($('#chatbot').hasClass('collapsed')) {
                var collapsedBtn = $('.collapsed-circle-btn')[0];
                if (collapsedBtn) {
                    var collapsedRect = collapsedBtn.getBoundingClientRect();
                    window.collapsedInitialLeft = collapsedRect.left;
                    window.collapsedInitialTop = collapsedRect.top;
                }
            }
        });

        // Also handle mousedown directly on collapsed-circle-btn and all its children to ensure drag works
        $(document).on('mousedown', '.collapsed-circle-btn, .collapsed-circle-btn *', function (e) {
            // Prevent default to avoid text selection and tooltip
            e.preventDefault();
            e.stopPropagation();

            // Remove any title attributes temporarily to prevent tooltip
            var $target = $(this).closest('.collapsed-circle-btn');
            if ($target.length > 0) {
                $target.attr('data-original-title', $target.attr('title') || '');
                $target.removeAttr('title');
                $target.find('*').each(function () {
                    $(this).attr('data-original-title', $(this).attr('title') || '');
                    $(this).removeAttr('title');
                });
            }

            // Initialize drag variables for collapsed circle button
            hasMoved = false;
            isDragging = false;
            dragStartTime = Date.now();

            startX = e.clientX;
            startY = e.clientY;

            var chatbot = $('#chatbot')[0];
            if (!chatbot) return;

            var rect = chatbot.getBoundingClientRect();
            initialLeft = rect.left;
            initialTop = rect.top;

            // Get the collapsed-circle-btn element (might be this or parent)
            var collapsedBtn = $(this).closest('.collapsed-circle-btn')[0] || $(this)[0];
            if (collapsedBtn) {
                var collapsedRect = collapsedBtn.getBoundingClientRect();
                window.collapsedInitialLeft = collapsedRect.left;
                window.collapsedInitialTop = collapsedRect.top;
            }

            // Add dragging class immediately to prevent tooltips
            $('#chatbot').addClass('dragging');
        });

        // Mouse move event - perform drag
        $(document).on('mousemove', function (e) {
            if (startX === undefined || startY === undefined) return;

            // Calculate distance moved
            var deltaX = Math.abs(e.clientX - startX);
            var deltaY = Math.abs(e.clientY - startY);

            // Check if we're dragging from collapsed-circle-btn - start immediately
            var isCollapsedDrag = $('#chatbot').hasClass('collapsed') && window.collapsedInitialLeft !== undefined;
            var threshold = isCollapsedDrag ? 0 : dragThreshold; // Start immediately (0 threshold) for collapsed button

            // If dragging class is already set (from collapsed button mousedown), start immediately
            if ($('#chatbot').hasClass('dragging') && !isDragging) {
                hasMoved = true;
                isDragging = true;
            }
            // Only start dragging if moved more than threshold
            else if (!hasMoved && (deltaX > threshold || deltaY > threshold)) {
                hasMoved = true;
                isDragging = true;
                $('#chatbot').addClass('dragging');
            }

            if (!isDragging) return;

            // Prevent default to avoid text selection and tooltip
            e.preventDefault();

            // Calculate new position
            var moveX = e.clientX - startX;
            var moveY = e.clientY - startY;

            var newLeft = initialLeft + moveX;
            var newTop = initialTop + moveY;

            // Keep chatbot within viewport bounds
            var maxLeft = window.innerWidth - chatbot.offsetWidth;
            var maxTop = window.innerHeight - chatbot.offsetHeight;

            newLeft = Math.max(0, Math.min(newLeft, maxLeft));
            newTop = Math.max(0, Math.min(newTop, maxTop));

            // Update position
            $(chatbot).css({
                'left': newLeft + 'px',
                'top': newTop + 'px',
                'right': 'auto',
                'bottom': 'auto'
            });

            // If collapsed, also update collapsed-circle-btn position
            if ($('#chatbot').hasClass('collapsed')) {
                var collapsedBtn = $('.collapsed-circle-btn');
                if (collapsedBtn.length > 0 && window.collapsedInitialLeft !== undefined) {
                    var collapsedMoveX = e.clientX - startX;
                    var collapsedMoveY = e.clientY - startY;
                    var collapsedNewLeft = window.collapsedInitialLeft + collapsedMoveX;
                    var collapsedNewTop = window.collapsedInitialTop + collapsedMoveY;

                    // Keep within viewport
                    var maxLeft = window.innerWidth - collapsedBtn[0].offsetWidth;
                    var maxTop = window.innerHeight - collapsedBtn[0].offsetHeight;
                    collapsedNewLeft = Math.max(0, Math.min(collapsedNewLeft, maxLeft));
                    collapsedNewTop = Math.max(0, Math.min(collapsedNewTop, maxTop));

                    collapsedBtn.css({
                        'left': collapsedNewLeft + 'px',
                        'top': collapsedNewTop + 'px',
                        'right': 'auto',
                        'bottom': 'auto'
                    });
                }
            }

            e.preventDefault();
        });

        // Mouse up event - end drag
        $(document).on('mouseup', function (e) {
            // If we were dragging, prevent click event
            if (isDragging || hasMoved) {
                window.chatbotWasDragging = true;
                e.stopPropagation();
                e.preventDefault();

                // Reset flag after a short delay to allow click handler to check it
                setTimeout(function () {
                    window.chatbotWasDragging = false;
                    isDragging = false;
                }, 100);
            }

            // Reset drag state
            if (isDragging || hasMoved) {
                hasMoved = false;
                $('#chatbot').removeClass('dragging');
                startX = undefined;
                startY = undefined;
                window.collapsedInitialLeft = undefined;
                window.collapsedInitialTop = undefined;

                // Restore title attributes if they were removed
                var $collapsedBtn = $('.collapsed-circle-btn');
                if ($collapsedBtn.length > 0) {
                    if ($collapsedBtn.attr('data-original-title')) {
                        $collapsedBtn.attr('title', $collapsedBtn.attr('data-original-title'));
                        $collapsedBtn.removeAttr('data-original-title');
                    }
                    $collapsedBtn.find('*').each(function () {
                        if ($(this).attr('data-original-title')) {
                            $(this).attr('title', $(this).attr('data-original-title'));
                            $(this).removeAttr('data-original-title');
                        }
                    });
                }
            }
        });

        // Prevent click event if we were dragging
        $(chatbot).on('click', function (e) {
            // If this was a drag operation, prevent the click
            if (window.chatbotWasDragging === true) {
                e.stopPropagation();
                e.preventDefault();
                return false;
            }
        });

        // Touch events for mobile support
        var touchStartX, touchStartY, touchInitialLeft, touchInitialTop;
        var touchHasMoved = false;
        var touchIsDragging = false;

        $(chatbot).on('touchstart', function (e) {
            var touch = e.originalEvent.touches[0];

            // Only exclude actual interactive buttons
            if (isInteractiveButton(e.target)) {
                return;
            }

            touchHasMoved = false;
            touchIsDragging = false;

            touchStartX = touch.clientX;
            touchStartY = touch.clientY;

            var rect = chatbot.getBoundingClientRect();
            touchInitialLeft = rect.left;
            touchInitialTop = rect.top;

            // If collapsed, also get the collapsed-circle-btn position
            if ($('#chatbot').hasClass('collapsed')) {
                var collapsedBtn = $('.collapsed-circle-btn')[0];
                if (collapsedBtn) {
                    var collapsedRect = collapsedBtn.getBoundingClientRect();
                    window.touchCollapsedInitialLeft = collapsedRect.left;
                    window.touchCollapsedInitialTop = collapsedRect.top;
                }
            }
        });

        // Also handle touchstart directly on collapsed-circle-btn and all its children
        $(document).on('touchstart', '.collapsed-circle-btn, .collapsed-circle-btn *', function (e) {
            var touch = e.originalEvent.touches[0];

            // Don't stop propagation - we need touchmove on document to work
            e.preventDefault();

            touchHasMoved = false;
            touchIsDragging = false;

            touchStartX = touch.clientX;
            touchStartY = touch.clientY;

            var chatbot = $('#chatbot')[0];
            if (!chatbot) return;

            var rect = chatbot.getBoundingClientRect();
            touchInitialLeft = rect.left;
            touchInitialTop = rect.top;

            // Get the collapsed-circle-btn element
            var collapsedBtn = $(this).closest('.collapsed-circle-btn')[0] || $(this)[0];
            if (collapsedBtn) {
                var collapsedRect = collapsedBtn.getBoundingClientRect();
                window.touchCollapsedInitialLeft = collapsedRect.left;
                window.touchCollapsedInitialTop = collapsedRect.top;
            }
        });

        $(document).on('touchmove', function (e) {
            if (touchStartX === undefined || touchStartY === undefined) return;

            var touch = e.originalEvent.touches[0];
            var deltaX = Math.abs(touch.clientX - touchStartX);
            var deltaY = Math.abs(touch.clientY - touchStartY);

            // Only start dragging if moved more than threshold
            if (!touchHasMoved && (deltaX > dragThreshold || deltaY > dragThreshold)) {
                touchHasMoved = true;
                touchIsDragging = true;
                $('#chatbot').addClass('dragging');
            }

            if (!touchIsDragging) return;

            var moveX = touch.clientX - touchStartX;
            var moveY = touch.clientY - touchStartY;

            var newLeft = touchInitialLeft + moveX;
            var newTop = touchInitialTop + moveY;

            var maxLeft = window.innerWidth - chatbot.offsetWidth;
            var maxTop = window.innerHeight - chatbot.offsetHeight;

            newLeft = Math.max(0, Math.min(newLeft, maxLeft));
            newTop = Math.max(0, Math.min(newTop, maxTop));

            $(chatbot).css({
                'left': newLeft + 'px',
                'top': newTop + 'px',
                'right': 'auto',
                'bottom': 'auto'
            });

            // If collapsed, also update collapsed-circle-btn position
            if ($('#chatbot').hasClass('collapsed')) {
                var collapsedBtn = $('.collapsed-circle-btn');
                if (collapsedBtn.length > 0 && window.touchCollapsedInitialLeft !== undefined) {
                    var collapsedMoveX = touch.clientX - touchStartX;
                    var collapsedMoveY = touch.clientY - touchStartY;
                    var collapsedNewLeft = window.touchCollapsedInitialLeft + collapsedMoveX;
                    var collapsedNewTop = window.touchCollapsedInitialTop + collapsedMoveY;

                    // Keep within viewport
                    var maxLeft = window.innerWidth - collapsedBtn[0].offsetWidth;
                    var maxTop = window.innerHeight - collapsedBtn[0].offsetHeight;
                    collapsedNewLeft = Math.max(0, Math.min(collapsedNewLeft, maxLeft));
                    collapsedNewTop = Math.max(0, Math.min(collapsedNewTop, maxTop));

                    collapsedBtn.css({
                        'left': collapsedNewLeft + 'px',
                        'top': collapsedNewTop + 'px',
                        'right': 'auto',
                        'bottom': 'auto'
                    });
                }
            }

            e.preventDefault();
        });

        $(document).on('touchend', function (e) {
            if (touchIsDragging || touchHasMoved) {
                window.chatbotWasDragging = true;
                e.stopPropagation();
                e.preventDefault();

                // Reset flag after a short delay
                setTimeout(function () {
                    window.chatbotWasDragging = false;
                }, 100);
            }

            if (touchIsDragging || touchHasMoved) {
                touchIsDragging = false;
                touchHasMoved = false;
                $('#chatbot').removeClass('dragging');
                touchStartX = undefined;
                touchStartY = undefined;
                window.touchCollapsedInitialLeft = undefined;
                window.touchCollapsedInitialTop = undefined;
            }
        });
        // ========== END DRAG AND DROP FUNCTIONALITY ==========

        // ========== TOOLTIP POSITIONING ==========
        // Position tooltip dynamically - ABOVE and to the LEFT of the icon
        function positionTooltip() {
            var $collapsedBtn = $('.collapsed-circle-btn');
            var $tooltip = $('.plus-icon-tooltip');

            if ($collapsedBtn.length === 0 || $tooltip.length === 0) return;

            // Get the position of the collapsed button
            var btnRect = $collapsedBtn[0].getBoundingClientRect();

            // Calculate tooltip dimensions
            var tooltipWidth = $tooltip.outerWidth() || 240; // fallback to min-width
            var tooltipHeight = $tooltip.outerHeight() || 45;
            var spacing = 15; // space between button and tooltip
            var margin = 15; // margin from screen edges

            // Position ABOVE and to the LEFT of the icon
            // Align tooltip right edge with button right edge, then shift left
            var left = btnRect.right - tooltipWidth; // Start from right edge of button
            var top = btnRect.top - tooltipHeight - spacing; // Above the button

            // Ensure tooltip stays within viewport
            var viewportWidth = window.innerWidth;
            var viewportHeight = window.innerHeight;

            // Adjust if tooltip goes off left edge
            if (left < margin) {
                left = margin;
            }

            // Adjust if tooltip goes off right edge
            if (left + tooltipWidth > viewportWidth - margin) {
                left = viewportWidth - tooltipWidth - margin;
            }

            // Adjust if tooltip goes off top edge - show below instead
            if (top < margin) {
                top = btnRect.bottom + spacing;
                // Change arrow position when tooltip is below
                $tooltip.addClass('tooltip-below');
            } else {
                $tooltip.removeClass('tooltip-below');
            }

            // Adjust if tooltip goes off bottom edge
            if (top + tooltipHeight > viewportHeight - margin) {
                top = viewportHeight - tooltipHeight - margin;
            }

            // Calculate arrow position to point to the center of the button
            // Arrow should be at the bottom of tooltip, pointing down to button center
            var buttonCenterX = btnRect.left + (btnRect.width / 2);
            var arrowOffset = buttonCenterX - left; // Distance from left edge of tooltip to button center

            // Ensure arrow stays within tooltip bounds (with some margin from edges)
            var arrowMargin = 20; // Minimum distance from tooltip edges
            arrowOffset = Math.max(arrowMargin, Math.min(arrowOffset, tooltipWidth - arrowMargin));

            // Apply position
            $tooltip.css({
                'left': left + 'px',
                'top': top + 'px',
                'bottom': 'auto',
                'right': 'auto',
                '--arrow-left': arrowOffset + 'px'
            });
        }

        // Update tooltip position on hover with proper timing
        $(document).on('mouseenter', '.collapsed-circle-btn, .collapsed-circle-btn .plus-icon, .collapsed-circle-btn .plus-container', function () {
            // Small delay to ensure tooltip is visible and measured
            setTimeout(function () {
                positionTooltip();
                // Update again after a short delay to ensure accurate positioning
                setTimeout(function () {
                    positionTooltip();
                }, 50);
            }, 10);
        });

        // Also update on mouse move for smooth following (optional)
        $(document).on('mousemove', '.collapsed-circle-btn, .collapsed-circle-btn .plus-icon, .collapsed-circle-btn .plus-container', function () {
            if ($('.plus-icon-tooltip').is(':visible')) {
                positionTooltip();
            }
        });

        // Update tooltip position when chatbot is moved
        $(document).on('mouseup', function () {
            if ($('.plus-icon-tooltip').is(':visible')) {
                positionTooltip();
            }
        });

        // Update tooltip position on window resize
        $(window).on('resize', function () {
            if ($('.plus-icon-tooltip').is(':visible')) {
                positionTooltip();
            }
        });
        // ========== END TOOLTIP POSITIONING ==========

    });


</script>

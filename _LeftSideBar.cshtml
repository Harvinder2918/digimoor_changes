<script>
    $(document).ready(function () {
        if ($(window).width() <= 769) {

            // Fix dropdown positioning - make them inline, not floating
            $('.sidebar-menu .dropdown-menu').css({
                'position': 'static',
                'float': 'none',
                'width': '100%',
                'box-shadow': 'none',
                'border': 'none',
                'background-color': '#1a2a3a',
                'padding-left': '15px'
            });

            // Remove any existing click handlers on dropdown links to avoid conflicts
            $(document).off('click', '.sidebar-menu li.dropdown > a');

            // Handle sidebar dropdown toggle on mobile
            $(document).on('click', '.sidebar-menu li.dropdown > a', function (e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation(); // Stop AdminLTE from interfering

                var $parentLi = $(this).closest('li.dropdown');
                var $dropdownMenu = $parentLi.find('> .dropdown-menu'); // Direct child only
                var isOpen = $parentLi.hasClass('open');

                // Close all other open dropdowns first
                $('.sidebar-menu li.dropdown').not($parentLi).find('> .dropdown-menu').slideUp(200);
                $('.sidebar-menu li.dropdown').not($parentLi).removeClass('open');

                // Toggle current one based on state
                if (isOpen) {
                    $dropdownMenu.slideUp(200);
                    $parentLi.removeClass('open');
                } else {
                    $dropdownMenu.slideDown(200);
                    $parentLi.addClass('open');
                }
            });

            // Close dropdown if clicking outside sidebar
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.main-sidebar').length) {
                    $('.sidebar-menu li.dropdown .dropdown-menu').slideUp(200);
                    $('.sidebar-menu li.dropdown').removeClass('open');
                }
            });
        }
    });
</script>
    var currentYear = "";
    var currentRopeTail = "";

    var Titles = $("@string.Format("#Trendgraph__TTL{0}", Model.chartId)").val();
    var lbls = $("@string.Format("#Trendgraph_lbl{0}", Model.chartId)").val().replace(/\u200B/g, '');

    var Lines = $("@string.Format("#Trendgraph_lin{0}", Model.chartId)").val().replace(/\u200B/g, '');
    var tails = $("@string.Format("#Trendgraph_tail{0}", Model.chartId)").val().replace(/\u200B/g, '');
    var ropetailIsused = $("@string.Format("#Trendgraph_ropetailIsused{0}", Model.chartId)").val() === 'true';

    var LinesnumberArray = Lines.split(',').map(Number);
    var tailsnumberArray = tails.split(',').map(Number);
    var lblssnumberArray = lbls.split(',').map(Number);

    /* ======================================
   FIX: START GRAPH FROM FIRST VALID YEAR
   ====================================== */
    if (lblssnumberArray.length > 0 && lblssnumberArray[0] === 0) {
        lblssnumberArray.shift();     // remove year 0
        LinesnumberArray.shift();     // remove matching Lines value
        if (tailsnumberArray.length > 0) {
            tailsnumberArray.shift(); // remove matching Tails value
        }
    }

    // Show all items regardless of Tails value - don't filter out any
    if (!ropetailIsused) {
        // If ropetailIsused is false, remove tails dataset completely but keep all labels
        tailsnumberArray = [];
    }
    // If ropetailIsused is true, show ALL items (don't filter based on Tails value)
    // Keep all original arrays as-is

    @*var maxval = @Model.chartId;*@

    //// Calculate highest value from all datasets
    var highestValue = 0;

    filteredData.forEach(function (dataset) {
        dataset.data.forEach(function (val) {
            if (val > highestValue) {
                highestValue = val;
            }
        });
    });

    // Determine dynamic step size
    var stepSize;

    // Decide grid division based on maxval range
    if (highestValue > 1 && highestValue <= 10) {
        stepSize = 1;     // 2,4,6,8,10
    }
    else if (highestValue > 10 && highestValue <= 50) {
        stepSize = 5;    // 10,20,30,40,50
    }
    else if (highestValue > 50 && highestValue <= 100) {
        stepSize = 10;    // 20,40,60,80,100
    }
    else if (highestValue > 100 && highestValue <= 250) {
        stepSize = 20;    // 50,100,150,200,250
    }
    else if (highestValue > 250) {
        stepSize = 50;   // 100,200,300,400...
    }
    else {
        stepSize = 1;
    }

    var maxval = (Math.floor(highestValue / stepSize) * stepSize) + stepSize;

    // Build datasets array conditionally
    var datasetsArray = [
        {
            label: 'Lines', // Label for the first dataset
            data: LinesnumberArray, // Y values for lines
            borderColor: 'rgba(102, 187, 172)', // Color for the line
            fill: false // Do not fill under the line
        }
    ];

    // Only add Tails dataset if ropetailIsused is true and there are tail values
    if (ropetailIsused && tailsnumberArray.length > 0) {
        datasetsArray.push({
            label: 'Tails', // Label for the second dataset
            data: tailsnumberArray, // Y values for tails
            borderColor: 'rgba(246, 134, 90)', // Color for the line
            fill: false // Do not fill under the line
        });
    }

    var ctx4 = $("@string.Format("#Trendgraph{0}", Model.chartId)");
    const myChart32 = new Chart(ctx4, {
        type: 'line', // Specify that we want a line chart
        data: {
            labels: lblssnumberArray, // X-axis labels
            datasets: datasetsArray
        },
        options: {
            responsive: true,
            hover: {
                animationDuration: 1
            },
            animation: {
                duration: 1,
                onComplete: function () {
                    const chartInstance = this.chart;
                    const ctx = chartInstance.ctx;

                    ctx.font = Chart.helpers.fontString(
                        Chart.defaults.global.defaultFontSize,
                        Chart.defaults.global.defaultFontStyle,
                        Chart.defaults.global.defaultFontFamily
                    );
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'bottom';

                    this.data.datasets.forEach(function (dataset, i) {
                        const meta = chartInstance.controller.getDatasetMeta(i);
                        meta.data.forEach(function (point, index) {
                            const data = dataset.data[index];
                            ctx.fillText(data, point._model.x, point._model.y - 5);
                        });
                    });
                }
            },
            title: {
                display: true,
                text: Titles // Ensure Titles is defined
            },
            legend: {
                display: true,
                align: 'left'
            },
            tooltips: {
                enabled: true
            },
            scales: {
                y: { // For Chart.js 3.x and later
                    beginAtZero: false,
                    title: {
                        display: true,
                        text: 'Count'
                    },
                    ticks: {
                        max: maxval, // Set max value if needed
                        display: true,
                        beginAtZero: true,
                        stepSize: stepSize,
                        precision: 0
                    }
                },
                x: { // For Chart.js 3.x and later
                    title: {
                        display: true,
                        text: 'Year'
                    },
                    ticks: {
                        autoSkip: false // Show all labels
                    }
                }
            },

            onClick: function (evt) {

                var activePoint = this.getElementAtEvent(evt);

                if (activePoint.length > 0) {

                    var chart = this;

                    var firstPoint = activePoint[0];
                    var datasetIndex = firstPoint._datasetIndex;
                    var elementIndex = firstPoint._index;

                    var Year = chart.data.labels[elementIndex];

                    // Get correct dataset label
                    var ropeTail = chart.data.datasets[datasetIndex].label;

                    if (ropeTail.toLowerCase() === "tails" || ropeTail.toLowerCase() === "tail") {
                        ropeTail = 1;
                    }
                    else {
                        ropeTail = 0;
                    }

                    currentYear = Year;
                    currentRopeTail = ropeTail;

                    loadYearlyTrendPage(1);

                }
            }

        }
    });






    //                backgroundColor: 'rgba(188, 143, 143, 0.5)', // Color for the bars
    //                /*borderColor: 'rgba(188, 143, 143, 1)',*/ // Color for the border
    //                borderWidth: 1 // Width of the bar border
    //            }
    //        ]
    //    },
    //    options: {
    //        responsive: false,
    //        scales: {
    //            y: {
    //                beginAtZero: true,
    //                title: {
    //                    display: true,
    //                    text: 'Count'
    //                }
    //            },
    //            x: {
    //                title: {
    //                    display: true,
    //                    text: 'Year'
    //                }
    //            }
    //        },
    //        plugins: {
    //            legend: {
    //                display: true,
    //                position: 'top'
    //            },
    //            title: {
    //                display: true,
    //                text: 'Trend Graph: Lines and Tails'
    //            }
    //        }
    //    }
    //});

</script>


<script>


    function loadYearlyTrendPage(pageNumber) {

        $("#yearlyTrendModal").modal('show')

        $("#yearlyTrendmodalLoader").show();

        var dateFrom = $("#TestDateFrom").val();

        var dateTo = $("#TestDateTo").val();


          $.ajax({
              url: '@Url.Action("GetDamageObservedGDetails", "Reports")',
              type: 'GET',
              data: {
                  Filter: currentYear,
                  RopeTail: currentRopeTail,
                  GType: "YearlyTrend",
                  DateFrom: dateFrom,
                  DateTo: dateTo,
                  pn: pageNumber
              },
              success: function (response) {

                  $("#yearlyTrendmodalContentArea").html(response);

              },
              error: function () {
                  alert("Error loading data.");
              },
              complete: function () {

                  // 🔥 Hide loader after success OR error
                  $("#yearlyTrendmodalLoader").hide();
              }
          });
    }



</script>



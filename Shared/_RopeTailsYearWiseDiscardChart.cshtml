</div>
<style>
body.scroll-lock {
    position: fixed;
    width: 100%;
    overflow: hidden;
}
</style>

<script>

var scrollPosition = 0;
var modalCount = 0; // tracks how many modals are open

function lockScroll() {
    if (modalCount === 0) {
        scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
        $('body').addClass('scroll-lock');
        $('body').css('top', -scrollPosition + 'px');
    }
    modalCount++;
}

function unlockScroll() {
    modalCount--;

    if (modalCount <= 0) {
        modalCount = 0;
        $('body').removeClass('scroll-lock');
        $('body').css('top', '');
        window.scrollTo(0, scrollPosition);
    }
}

// Apply to BOTH modals
$('#ageBasedModal, #ImageModal').on('show.bs.modal', function () {
    lockScroll();
});

$('#ageBasedModal, #ImageModal').on('hidden.bs.modal', function () {
    unlockScroll();
});

</script>